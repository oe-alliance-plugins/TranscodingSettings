msgstr "Transcoding-Port"

#: ../configuration.py:101
msgid "Very Low"
msgstr "Sehr niedrig"

#. XML context: item attribute 'description'
#: ../setup.xml:47
msgid "Video codec used by encoder 1 for normal transcoding."
msgstr "Videocodec, den Encoder 1 für normales Transcoding verwendet."

#. XML context: item attribute 'description'
#: ../setup.xml:32
msgid "Video codec used for normal transcoding. HLS/RTSP has a separate codec selection restricted to H.264 and H.265. Some older BCM encoders support only H.264."
msgstr "Videocodec für normales Transcoding. HLS/RTSP hat eine separate Codec-Auswahl, die auf H.264 und H.265 beschränkt ist. Einige ältere BCM-Encoder unterstützen nur H.264."
